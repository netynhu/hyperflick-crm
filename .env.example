# ===== Servidor =====
PORT=3000
# Domínio público onde o sistema vai rodar (usado no webhook da uazapi).
# Em produção: https://seudominio.com  | Em teste local com ngrok: https://xxxx.ngrok-free.app
PUBLIC_URL=http://localhost:3000

# ===== Supabase =====
# Project Settings > API
SUPABASE_URL=https://xxxxxxxx.supabase.co
# Use a SERVICE ROLE key (server-side apenas, NUNCA exponha no frontend)
SUPABASE_SERVICE_KEY=eyJhbGciOi...
# Anon/public key (usada no login do CRM via Supabase Auth — pode ir pro frontend)
SUPABASE_ANON_KEY=eyJhbGciOi...

# ===== uazapi (WhatsApp) =====
# URL do seu servidor uazapi (ex: https://free.uazapi.com ou seu self-hosted)
UAZAPI_URL=https://free.uazapi.com
# Admin token da sua conta uazapi (usado para CRIAR e gerenciar instâncias)
UAZAPI_ADMIN_TOKEN=seu-admin-token-aqui

# ===== Teste grátis (IPTV) =====
# Duração do teste em horas (usado só se o painel não retornar a validade)
TEST_DURATION_HOURS=6
# URL/DNS do seu painel que o cliente coloca no app de IPTV (fallback)
IPTV_PANEL_URL=http://seupainel.com:80

# Endpoint de chatbot do painel (uhdpainel) que GERA o teste real e retorna usuário/senha
PANEL_CHATBOT_URL=https://p.uhdpainel.com.br/api/chatbot/BKADdVe1lr/qK4WrQDeNj
# Mensagem enviada ao chatbot do painel para disparar a geração do teste
PANEL_TRIGGER=teste

# ===== Preços dos planos (R$) =====
PRICE_MENSAL=19.90
PRICE_SEMESTRAL=79.90
PRICE_ANUAL=129.90

# ===== Segurança do painel CRM =====
# Senha simples para acessar o dashboard /crm (header x-admin-key)
CRM_ADMIN_KEY=troque-esta-senha
